# ============================================
# Music Text Generator - Configurazione
# Versione 3.1.0
# ============================================

# ============================================
# SICUREZZA
# ============================================

# Autenticazione API (opzionale)
# Se abilitata, richiede X-API-Key header in tutte le richieste
ENABLE_AUTH=false
# API keys valide (separate da virgola)
# Esempio: API_KEYS=key1,key2,key3
API_KEYS=

# Rate Limiting
RATE_LIMIT_REQUESTS=10  # Richieste per finestra
RATE_LIMIT_WINDOW=60    # Finestra in secondi (60 = 1 minuto)

# ============================================
# REDIS (Job Persistence)
# ============================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
JOB_EXPIRY_HOURS=24  # Ore prima di eliminare job vecchi

# ============================================
# FILE MANAGEMENT
# ============================================

# Directory
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
TEMP_DIR=  # Vuoto = usa temp di sistema

# Limiti file
MAX_FILE_SIZE_MB=100  # Dimensione massima upload (MB)
FILE_MAX_AGE_HOURS=24  # Ore prima di eliminare file vecchi
CLEANUP_ENABLED=true   # Abilita cleanup automatico

# ============================================
# PERFORMANCE
# ============================================

MAX_WORKERS=4  # Thread workers per processamento parallelo

# ============================================
# AI PROVIDERS
# ============================================

# OpenAI (opzionale)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# Ollama (locale - consigliato)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# DeepSeek (opzionale)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Claude/Anthropic (opzionale)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ============================================
# SEPARAZIONE VOCALE
# ============================================

# Disabilita Spleeter per usare metodi veloci (fallback)
USE_SPLEETER=true

# ============================================
# LOGGING
# ============================================

LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR